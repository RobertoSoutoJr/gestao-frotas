{
  "expo": {
    "name": "FuelTrack",
    "slug": "fueltrack",
    "scheme": "fueltrack",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f23"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fueltrack.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O FuelTrack usa sua localização para registrar o início e fim das viagens.",
        "NSCameraUsageDescription": "O FuelTrack usa a câmera para fotografar comprovantes de abastecimento e manutenção.",
        "NSPhotoLibraryUsageDescription": "O FuelTrack acessa suas fotos para anexar comprovantes."
      }
    },
    "android": {
      "package": "com.fueltrack.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f23"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-updates",
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O FuelTrack usa sua localização para registrar o início e fim das viagens."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O FuelTrack acessa suas fotos para anexar comprovantes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6c63ff",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O FuelTrack usa a câmera para fotografar cupons fiscais e comprovantes."
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/2006f5c0-7ed6-455c-9dcb-9230560f67ff",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_ERROR_RECOVERY"
    },
    "extra": {
      "apiUrl": "https://srv1665848.hstgr.cloud/api",
      "router": {},
      "eas": {
        "projectId": "2006f5c0-7ed6-455c-9dcb-9230560f67ff"
      }
    },
    "owner": "jrsouto"
  }
}
